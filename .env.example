# ─────────────────────────────────────────────────────────────────────
# Action Marshall — example environment file
#
# Copy this to `.env` at the repo root and edit values you actually
# need. `docker compose up` reads this automatically. The compose file
# provides safe local defaults for everything, so a fresh checkout
# works without any edits here.
#
# For production deployments see docs/deployment.md.
# ─────────────────────────────────────────────────────────────────────


# ── Required in production ───────────────────────────────────────────

# HMAC key for signing audit receipts. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The default below is unsafe — it's only useful for local dev. In
# production the backend will refuse to start without a real value.
PROOF_SECRET=action_marshall-dev-secret-change-in-production

# Seed org and API key created on first run by init_db(). The API key
# is hashed in the database; rotate it by setting a new value and
# restarting the backend (the old key keeps working until you delete it).
DEFAULT_ORG_ID=org_demo
DEFAULT_API_KEY=am_test_demo_key_001


# ── Backend ──────────────────────────────────────────────────────────

# Origins allowed by CORS. Comma-separated list. The UI's URL must be
# in this list or browser fetches will be blocked.
ALLOWED_ORIGINS=http://localhost:3000

# Where the SQLite database lives inside the backend container. The
# compose file mounts a named volume at /app/data so this survives
# restarts.
DATABASE_PATH=/app/data/action_marshall.db


# ── UI ───────────────────────────────────────────────────────────────

# IMPORTANT: NEXT_PUBLIC_* values are baked into the UI's static bundle
# at *build* time, not at container start. Changing them requires a
# rebuild (`docker compose build ui`).
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=am_test_demo_key_001


# ── Slack approvals (optional) ───────────────────────────────────────

# Incoming webhook URL. When set, the backend posts approval requests
# to this channel. Leave blank to disable Slack entirely — the
# `awaiting_approval` flow still works via the web UI.
SLACK_WEBHOOK_URL=


# ── Live ServiceNow connector (optional) ─────────────────────────────

# Required only if you run actions with `params.connector=servicenow_real`.
# Leave blank to keep using the built-in simulator (`servicenow_sim`).
SNOW_INSTANCE=
SNOW_USERNAME=
SNOW_PASSWORD=


# ── Employee 2FA email (optional) ────────────────────────────────────

# Required for OTP delivery during employee signup / login. With these
# blank the backend logs OTPs to stdout instead of sending email — that's
# fine for local dev, never for production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true


# ── Agent registration policy (optional) ─────────────────────────────

# When `true`, unknown agents are rejected outright. When unset/false,
# the backend auto-registers unknown agents in a pending_registration
# state. Set to `true` once your org has finished onboarding agents.
MARSHALL_REQUIRE_PREREGISTERED_AGENTS=false
