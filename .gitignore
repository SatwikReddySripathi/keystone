# ──────────────────────────────────────────────
# Keystone — .gitignore
# ──────────────────────────────────────────────

# ── Secrets & environment ──────────────────────
.env
.env.*
!.env.example
backend/.env
ui/.env.local
ui/.env*.local
*.key
*.pem
*.p12
*.pfx
secrets/

# ── Database ───────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ── Python ─────────────────────────────────────
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/
*.log

# SDK build artifacts
sdk/keystone.egg-info/
sdk/dist/
sdk/build/

# ── Node / Next.js (recursive — matches ui/, website/, anywhere) ─
node_modules/
.next/
out/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts
.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*


website/node_modules
website/.next
# ── Internal / dev-only files ──────────────────
CLAUDE.md
sdk/demo_real.py
ngrok.exe
*.ngrok-v3.yml

# ── Local assets not tracked publicly ──────────
# Pitch deck and similar artifacts live under assets/ for local convenience
# but are not committed to the public repo.
assets/pitch/

# ── IDE ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.cursor/

# ── OS ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
