# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Application
DATABASE_PATH=keystone.db
DEFAULT_ORG_ID=org_demo
DEFAULT_API_KEY=ks_test_demo_key_001

# Proof signing secret — change this in production
PROOF_SECRET=change-me-use-a-long-random-string

# Slack (optional — required only for Slack approval flow)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ServiceNow real connector (optional — required only for servicenow_real connector)
SNOW_INSTANCE=your-dev-instance
SNOW_USERNAME=admin
SNOW_PASSWORD=your-password
